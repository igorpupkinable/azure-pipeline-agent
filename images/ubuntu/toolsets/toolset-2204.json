{
    "powershellModules": [
        {"name": "MarkdownPS"},
        {"name": "Microsoft.Graph"},
        {"name": "Pester"},
        {"name": "PSScriptAnalyzer"}
    ],
    "azureModules": [
        {
            "name": "az",
            "versions": [
                "14.6.0"
            ]
        }
    ],
    "apt": {
        "vital_packages": [
            "bzip2",
            "curl",
            "g++",
            "gcc",
            "make",
            "jq",
            "tar",
            "unzip",
            "wget"
        ]
    },
    "docker": {
        "components": [
            {
                "package": "containerd.io",
                "version": "latest"
            },
            {
                "package": "docker-ce-cli",
                "version": "28.0.4"
            },
            {
                "package": "docker-ce",
                "version": "28.0.4"
            }
        ],
        "plugins": [
            {
                "plugin": "buildx",
                "version": "latest",
                "asset": "linux-amd64"
            },
            {
                "plugin": "compose",
                "version": "2.38.2",
                "asset": "linux-x86_64"
            }
        ]
    },
    "gcc": {
        "versions": [
            "g++-12"
        ]
    },
    "pwsh": {
        "version": "7.4"
